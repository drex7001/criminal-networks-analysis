backups/

# T10 projection snapshot fixture (committed test baseline)
!tests/snapshots/real_graph.baseline.json

# T22 workspace: tracked JSON exceptions to *.json above. The lockfile is not
# optional — `npm ci` in the workspace CI job refuses to run without it (T16c),
# and openapi.json is the contract the typed client is generated from.
!ui/package.json
!ui/package-lock.json
!ui/openapi.json
!ui/tsconfig.json
