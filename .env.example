# --- Semantic pass (LangChain init_chat_model, provider-agnostic) ---
# Format: "provider:model". Install the matching langchain-<provider> package.
#   anthropic:claude-sonnet-5   (needs ANTHROPIC_API_KEY + langchain-anthropic)
#   openai:gpt-5                (needs OPENAI_API_KEY   + langchain-openai)
#   ollama:llama3               (local, no key          + langchain-ollama)
EXTRACTION_MODEL=google_genai:gemini-2.5-flash-lite
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Neo4j (only needed for --push; .cypher file export works without) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
