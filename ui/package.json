{
  "name": "aegis-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aegis investigation workspace — the single durable UI (ADR-032, spec 07)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate:api": "openapi-typescript openapi.json --default-non-nullable false --output src/api/schema.d.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "cytoscape": "^3.30.4",
    "oidc-client-ts": "^3.1.0",
    "openapi-fetch": "^0.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-oidc-context": "^3.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/cytoscape": "^3.21.8",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
