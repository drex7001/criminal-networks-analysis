{
  "realm": "aegis",
  "enabled": true,
  "displayName": "Aegis",
  "registrationAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Users/roles/ontology/infra — no intelligence content access (speckit spec 03 §2)" },
      { "name": "supervisor", "description": "Analyst powers + approvals, case membership, sealing (P6)" },
      { "name": "analyst", "description": "Claims, review queue, identity adjudication, analytics, own cases" },
      { "name": "investigator", "description": "Claims, evidence registration, custody events, case work" },
      { "name": "evidence_officer", "description": "Evidence registration and custody transfers only" },
      { "name": "auditor", "description": "Read audit log and all content incl. retracted/sealed; no writes" }
    ]
  },
  "clientScopes": [
    {
      "name": "aegis",
      "description": "Aegis token claims (clearance = index into ontology handling_codes)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "aegis-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "aegis-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "lightweight.claim": "false"
          }
        },
        {
          "name": "clearance",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "clearance",
            "claim.name": "clearance",
            "jsonType.label": "int",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "aegis-cli",
      "name": "Aegis dev CLI (password grant for local API testing only)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": ["aegis"],
      "optionalClientScopes": []
    },
    {
      "clientId": "aegis-ui",
      "name": "Aegis workspace (browser: authorization code + PKCE, T22/ADR-032)",
      "description": "This realm replaces the built-in clientScopes, so profile/email do not exist and requesting them fails with invalid_scope. The workspace asks for openid only; its claims come from the aegis scope. See ui/README.md.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "rootUrl": "http://127.0.0.1:8000",
      "redirectUris": [
        "http://127.0.0.1:8000",
        "http://localhost:8000",
        "http://127.0.0.1:5173",
        "http://localhost:5173",
        "http://127.0.0.1:4173",
        "http://localhost:4173",
        "http://127.0.0.1:8000/auth/callback",
        "http://localhost:8000/auth/callback",
        "http://127.0.0.1:5173/auth/callback",
        "http://localhost:5173/auth/callback",
        "http://127.0.0.1:4173/auth/callback",
        "http://localhost:4173/auth/callback"
      ],
      "webOrigins": [
        "http://127.0.0.1:8000",
        "http://localhost:8000",
        "http://127.0.0.1:5173",
        "http://localhost:5173",
        "http://127.0.0.1:4173",
        "http://localhost:4173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": ["aegis"],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "dev-analyst",
      "enabled": true,
      "email": "dev-analyst@aegis.local",
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "Analyst",
      "credentials": [{ "type": "password", "value": "analyst", "temporary": false }],
      "realmRoles": ["analyst"],
      "attributes": { "clearance": ["2"] }
    },
    {
      "username": "dev-auditor",
      "enabled": true,
      "email": "dev-auditor@aegis.local",
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "Auditor",
      "credentials": [{ "type": "password", "value": "auditor", "temporary": false }],
      "realmRoles": ["auditor"],
      "attributes": { "clearance": ["2"] }
    },
    {
      "username": "dev-admin",
      "enabled": true,
      "email": "dev-admin@aegis.local",
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["admin"],
      "attributes": { "clearance": ["0"] }
    }
  ]
}
